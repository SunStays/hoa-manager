generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Community {
  id                  String               @id @default(cuid())
  name                String
  address             String
  city                String
  country             String               @default("Netherlands")
  timezone            String               @default("Europe/Amsterdam")
  dueDayOfMonth       Int                  @default(1)
  logoUrl             String?
  stripeAccountId     String?
  subscriptionStatus  String               @default("trial")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  buildingPmEmail     String?
  buildingPmName      String?
  buildingPmPhone     String?
  amenities           Amenity[]
  announcements       Announcement[]
  documents           Document[]
  importantCodes      ImportantCode[]
  maintenanceRequests MaintenanceRequest[]
  threads             Thread[]
  units               Unit[]
  users               User[]
  votes               Vote[]
}

model Unit {
  id                  String               @id @default(cuid())
  communityId         String
  unitNumber          String
  address             String?
  floor               Int?
  sqm                 Int?
  monthlyDues         Decimal              @default(0)
  status              String               @default("occupied")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  pmEmail             String?
  pmName              String?
  pmPhone             String?
  maintenanceRequests MaintenanceRequest[]
  payments            Payment[]
  community           Community            @relation(fields: [communityId], references: [id], onDelete: Cascade)
  voteResponses       VoteResponse[]
  residents           User[]               @relation("UnitResidents")

  @@unique([communityId, unitNumber])
}

model User {
  id                  String               @id @default(cuid())
  communityId         String
  name                String
  email               String               @unique
  password            String?
  role                String               @default("resident")
  phone               String?
  pushToken           String?
  avatarUrl           String?
  emailVerified       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lastSeenAt          DateTime?
  accounts            Account[]
  amenityBookings     AmenityBooking[]
  announcements       Announcement[]
  sentMessages        DirectMessage[]      @relation("SentDirectMessages")
  uploadedDocuments   Document[]
  maintenanceRequests MaintenanceRequest[]
  maintenanceUpdates  MaintenanceUpdate[]
  payments            Payment[]
  pushSubscriptions   PushSubscription[]
  sessions            Session[]
  residentThread      Thread?              @relation("ResidentThreads")
  community           Community            @relation(fields: [communityId], references: [id], onDelete: Cascade)
  voteResponses       VoteResponse[]
  units               Unit[]               @relation("UnitResidents")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String    @id @default(cuid())
  unitId          String
  userId          String
  amount          Decimal
  description     String    @default("Monthly dues")
  dueDate         DateTime
  paidAt          DateTime?
  stripePaymentId String?
  status          String    @default("pending")
  createdAt       DateTime  @default(now())
  unit            Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id])
}

model MaintenanceRequest {
  id            String              @id @default(cuid())
  communityId   String
  unitId        String
  submittedById String
  title         String
  description   String
  priority      String              @default("medium")
  status        String              @default("open")
  photos        String[]
  notes         String?
  resolvedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  announcements Announcement[]
  community     Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  submittedBy   User                @relation(fields: [submittedById], references: [id])
  unit          Unit                @relation(fields: [unitId], references: [id])
  updates       MaintenanceUpdate[]
}

model MaintenanceUpdate {
  id        String             @id @default(cuid())
  requestId String
  authorId  String
  message   String
  status    String?
  createdAt DateTime           @default(now())
  author    User               @relation(fields: [authorId], references: [id])
  request   MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Announcement {
  id                   String              @id @default(cuid())
  communityId          String
  authorId             String
  title                String
  body                 String
  pinned               Boolean             @default(false)
  publishedAt          DateTime            @default(now())
  createdAt            DateTime            @default(now())
  attachments          String[]
  maintenanceRequestId String?
  author               User                @relation(fields: [authorId], references: [id])
  community            Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  maintenanceRequest   MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
}

model Vote {
  id          String         @id @default(cuid())
  communityId String
  question    String
  description String?
  options     String[]
  closesAt    DateTime
  createdAt   DateTime       @default(now())
  community   Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  responses   VoteResponse[]
}

model VoteResponse {
  id        String   @id @default(cuid())
  voteId    String
  userId    String
  option    String
  createdAt DateTime @default(now())
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  vote      Vote     @relation(fields: [voteId], references: [id], onDelete: Cascade)

  @@unique([voteId, unitId])
}

model Amenity {
  id               String           @id @default(cuid())
  communityId      String
  name             String
  description      String?
  maxGuests        Int              @default(10)
  requiresApproval Boolean          @default(true)
  createdAt        DateTime         @default(now())
  community        Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  bookings         AmenityBooking[]
}

model AmenityBooking {
  id         String   @id @default(cuid())
  amenityId  String
  userId     String
  startsAt   DateTime
  endsAt     DateTime
  guestCount Int      @default(1)
  notes      String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
}

model ImportantCode {
  id          String    @id @default(cuid())
  communityId String
  label       String
  value       String
  category    String    @default("general")
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id           String    @id @default(cuid())
  communityId  String
  uploadedById String
  title        String
  category     String    @default("other")
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  createdAt    DateTime  @default(now())
  year         Int?
  community    Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
}

model Thread {
  id          String          @id @default(cuid())
  communityId String
  residentId  String          @unique
  createdAt   DateTime        @default(now())
  messages    DirectMessage[]
  community   Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  resident    User            @relation("ResidentThreads", fields: [residentId], references: [id])
}

model DirectMessage {
  id        String    @id @default(cuid())
  threadId  String
  senderId  String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  sender    User      @relation("SentDirectMessages", fields: [senderId], references: [id])
  thread    Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
}
